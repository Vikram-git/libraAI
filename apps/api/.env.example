# Local dev (SQLite) — no install needed:
DATABASE_URL="file:./dev.db"

# Production (Supabase + pgvector):
# DATABASE_URL="postgresql://postgres:password@localhost:5432/libraai?schema=public"
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"
OPENAI_API_KEY="sk-..."
PORT=4000
CORS_ORIGIN="http://localhost:5173"

# Items API extension: require JWT for POST/PUT/DELETE
ITEMS_REQUIRE_AUTH=false
