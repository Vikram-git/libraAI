{
  "name": "libraai",
  "version": "1.0.0",
  "private": true,
  "description": "LibraAI – Smart Library Management Platform",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@libraai/api & npm run dev --workspace=@libraai/web",
    "dev:api": "npm run dev --workspace=@libraai/api",
    "dev:web": "npm run dev --workspace=@libraai/web",
    "dev:mobile": "npm run start --workspace=@libraai/mobile",
    "build": "npm run build --workspaces --if-present",
    "db:generate": "npm run db:generate --workspace=@libraai/api",
    "db:migrate": "npm run db:migrate --workspace=@libraai/api",
    "db:seed": "npm run db:seed --workspace=@libraai/api",
    "db:studio": "npm run db:studio --workspace=@libraai/api"
  },
  "engines": {
    "node": ">=20"
  }
}
